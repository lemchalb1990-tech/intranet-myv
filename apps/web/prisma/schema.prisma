generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  SUPER_ADMIN
  EXECUTIVE
  CLIENT
}

enum DocumentStatus {
  PENDING
  UPLOADED
  APPROVED
  REJECTED
}

enum DeliveryStatus {
  VERDE
  EN_BLANCO
  ENTREGA_INMEDIATA
}

model User {
  id        String   @id @default(cuid())
  rut       String?  @unique
  name      String
  email     String   @unique
  password  String
  role      Role     @default(CLIENT)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client             Client?
  assignedClients    Client[]   @relation("ExecutiveClients")
  reviewedDocuments  Document[] @relation("DocumentReviewer")
  requestedDocuments Document[] @relation("DocumentRequester")
  completedSteps     UnitStep[] @relation("StepCompletedBy")
}

model Client {
  id          String     @id @default(cuid())
  userId      String     @unique
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  phone       String?
  executiveId String?
  executive   User?      @relation("ExecutiveClients", fields: [executiveId], references: [id])
  projects    Unidad[]
  documents   Document[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Inmobiliaria {
  id        String     @id @default(cuid())
  name      String
  rut       String?
  address   String?
  proyectos Proyecto[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Proyecto {
  id              String          @id @default(cuid())
  inmobiliariaId  String
  inmobiliaria    Inmobiliaria    @relation(fields: [inmobiliariaId], references: [id], onDelete: Cascade)
  name            String
  type            String          @default("Departamento")
  address         String?
  deliveryStatus  DeliveryStatus?
  deliveryDate    DateTime?
  description     String?
  defaultStatusId String?
  defaultStatus   ProjectStatus?  @relation(fields: [defaultStatusId], references: [id], onDelete: SetNull)
  unidades        Unidad[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

model ProjectStatus {
  id              String     @id @default(cuid())
  name            String
  color           String     @default("#94a3b8")
  order           Int        @default(0)
  isDefault       Boolean    @default(false)
  projects        Unidad[]
  proyectoDefault Proyecto[]
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
}

model Unidad {
  id            String        @id @default(cuid())
  clientId      String
  client        Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  proyectoId    String?
  proyecto      Proyecto?     @relation(fields: [proyectoId], references: [id])
  unitNumber    String?
  hasStorage    Boolean       @default(false)
  storageNumber String?
  hasParking    Boolean       @default(false)
  parkingNumber String?
  name          String
  type          String        @default("Departamento")
  statusId      String
  status        ProjectStatus @relation(fields: [statusId], references: [id])
  deliveryDate  DateTime?
  notes         String?
  documents          Document[]
  steps              UnitStep[]
  notificationLogs   NotificationLog[]
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  @@map("projects")
}

model UnitStep {
  id             String     @id @default(cuid())
  unidadId       String
  unidad         Unidad     @relation(fields: [unidadId], references: [id], onDelete: Cascade)
  order          Int        @default(0)
  name           String
  description    String?
  notifyEnabled  Boolean    @default(false)
  notifyTemplate String?
  completedAt    DateTime?
  completedById  String?
  completedBy    User?      @relation("StepCompletedBy", fields: [completedById], references: [id])
  documents      Document[]
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
}

model Document {
  id            String         @id @default(cuid())
  title         String
  clientId      String
  client        Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  projectId     String?
  project       Unidad?        @relation(fields: [projectId], references: [id])
  stepId        String?
  step          UnitStep?      @relation(fields: [stepId], references: [id])
  requestedById String
  requestedBy   User           @relation("DocumentRequester", fields: [requestedById], references: [id])
  requestNote   String?
  fileName      String?
  fileUrl       String?
  fileType      String?
  fileSize      Int?
  status        DocumentStatus @default(PENDING)
  reviewNote    String?
  reviewedById  String?
  reviewedBy    User?          @relation("DocumentReviewer", fields: [reviewedById], references: [id])
  createdAt     DateTime       @default(now())
  uploadedAt    DateTime?
  reviewedAt    DateTime?
  updatedAt     DateTime       @updatedAt
}

model NotificationLog {
  id          String   @id @default(cuid())
  unidadId    String
  unidad      Unidad   @relation(fields: [unidadId], references: [id], onDelete: Cascade)
  stepName    String
  clientName  String
  clientEmail String
  sentByName  String
  subject     String
  body        String
  sentAt      DateTime @default(now())
}

model Settings {
  id             String   @id @default(cuid())
  platformName   String   @default("Intranet MYV")
  logoUrl        String?
  primaryColor   String   @default("#475569")
  accentColor    String   @default("#0f172a")
  emailProvider  String   @default("smtp")
  smtpHost       String?
  smtpPort       Int?     @default(587)
  smtpSecure     Boolean  @default(false)
  smtpUser       String?
  smtpPassword   String?
  smtpFrom       String?
  resendApiKey   String?
  resendFrom     String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}
